/**
 * @fileoverview Firestore Security Rules for Vexa AI application.
 *
 * Core Philosophy:
 * This ruleset provides public read access to services, client projects, and blog articles,
 * while restricting write access to authorized admins. Contact form entries are also
 * restricted to admins. No user-specific data or ownership models are enforced
 * directly in these rules, assuming admin privileges are managed by backend functions.
 *
 * Data Structure:
 * The Firestore database consists of four top-level collections:
 * - /services/{serviceId}: Stores information about services.
 * - /client_projects/{projectId}: Stores information about client projects.
 * - /blog_articles/{articleId}: Stores blog articles.
 * - /contact_form_entries/{entryId}: Stores contact form entries.
 *
 * Key Security Decisions:
 * - Public read access is granted for /services, /client_projects, and /blog_articles.
 * - All write operations are denied by default, assuming admin operations are handled server-side.
 * - No data validation is performed in these rules, as prototyping assumes flexible data shapes.
 *
 * Denormalization for Authorization:
 * No denormalization is required as the collections do not implement user-specific authorization.
 * It is assumed that backend functions handle admin roles and write access.
 *
 * Structural Segregation:
 * Collections are structurally segregated with clear public/admin separation, simplifying read/write rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to services, but restricts all writes.
     * @path /services/{serviceId}
     * @allow get, list: if true
     * @deny create, update, delete: if false
     * @principle Allows public reads, denies all writes, assuming write operations will be managed by backend functions.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to client projects, but restricts all writes.
     * @path /client_projects/{projectId}
     * @allow get, list: if true
     * @deny create, update, delete: if false
     * @principle Allows public reads, denies all writes, assuming write operations will be managed by backend functions.
     */
    match /client_projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to blog articles, but restricts all writes.
     * @path /blog_articles/{articleId}
     * @allow get, list: if true
     * @deny create, update, delete: if false
     * @principle Allows public reads, denies all writes, assuming write operations will be managed by backend functions.
     */
    match /blog_articles/{articleId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Restricts all access to contact form entries, assuming admin access is handled server-side.
     * @path /contact_form_entries/{entryId}
     * @deny get, list, create, update, delete: if false
     * @principle Denies all access, assuming operations will be managed by backend functions.
     */
    match /contact_form_entries/{entryId} {
      allow get, list, create, update, delete: if false;
    }
  }
}