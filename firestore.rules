/**
 * @fileoverview Firestore Security Rules for Vexa AI application.
 *
 * Core Philosophy:
 * This ruleset provides public read access to services, client projects, and blog articles,
 * while restricting write access to administrators. Contact form entries are accessible only to admins.
 *
 * Data Structure:
 * - /services/{serviceId}: Publicly readable service details.
 * - /client_projects/{projectId}: Publicly readable client project details.
 * - /blog_articles/{articleId}: Publicly readable blog articles.
 * - /contact_form_entries/{entryId}: Contact form submissions, accessible only to admins.
 *
 * Key Security Decisions:
 * - Public read access is granted for services, client projects, and blog articles.
 * - Administrative write access is assumed to be handled by backend functions (not covered by these rules).
 * - Listing all documents in the collection is allowed by default, since no user specific data exists.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to service details. Write access is restricted to admins (via backend).
     * @path /services/{serviceId}
     * @allow get, list: if true;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, admin-only write.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to client project details. Write access is restricted to admins (via backend).
     * @path /client_projects/{projectId}
     * @allow get, list: if true;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, admin-only write.
     */
    match /client_projects/{projectId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to blog articles. Write access is restricted to admins (via backend).
     * @path /blog_articles/{articleId}
     * @allow get, list: if true;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, admin-only write.
     */
    match /blog_articles/{articleId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Restricts access to contact form entries to authenticated admins.
     * @path /contact_form_entries/{entryId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Admin-only access.
     */
    match /contact_form_entries/{entryId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}