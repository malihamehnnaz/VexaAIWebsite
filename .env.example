# ─────────────────────────────────────────────────────────────────────────────
# Vexa AI Website — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and publishable (anon) key — safe to expose to the browser.
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Service role key — NEVER expose this to the browser (no NEXT_PUBLIC_ prefix).
# Bypasses Row Level Security. Found in: Supabase dashboard → Project Settings → API → Secret keys
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Found in: Azure portal → your OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# The deployment name you created in Azure OpenAI Studio (e.g. gpt-4o, gpt-4.1)
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# ── Resend (email) ────────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# PRODUCTION: must use a verified domain, e.g. noreply@yourdomain.com
# DEV only:   onboarding@resend.dev works but has a 100 email/day sandbox limit
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Where contact form submissions are delivered
RESEND_TO_EMAIL=you@yourdomain.com
# Reply-to address shown to the person who submitted the form
RESEND_OWNER_REPLY_TO=you@yourdomain.com

# ── Admin panel ───────────────────────────────────────────────────────────────
# Password to access /admin. Use a strong random string (20+ chars).
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
ADMIN_PANEL_PASSWORD=replace-with-strong-random-password

# Secret used to sign admin session tokens (HMAC-SHA256).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this invalidates all existing admin sessions.
SESSION_SECRET=replace-with-64-char-hex-secret

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
# Optional but strongly recommended in production.
# Without this, rate limiting uses in-memory storage that resets on cold starts.
# Free tier at: upstash.com → Create Database → copy REST URL and token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Firebase / Firestore (chat & traffic logging) ─────────────────────────────
# Used for Firestore-based event logging alongside Supabase.
# If not set, Firestore logging is silently skipped (app still works).
# Found in: Firebase console → Project Settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true to enable the fluid cursor visual effect
NEXT_PUBLIC_ENABLE_FLUID_CURSOR=false
